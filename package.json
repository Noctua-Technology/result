{
  "name": "@noctuatech/result",
  "version": "1.2.0",
  "type": "module",
  "main": "target/lib.js",
  "types": "target/lib.d.ts",
  "exports": {
    ".": {
      "types": "./target/lib.d.ts",
      "import": "./target/lib.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "wireit",
    "test": "wireit",
    "test:coverage": "wireit",
    "prepare": "husky"
  },
  "wireit": {
    "build": {
      "command": "tsc --build --pretty",
      "clean": "if-file-deleted",
      "files": [
        "src/**",
        "tsconfig.json"
      ],
      "output": [
        "target/**",
        "tsconfig.tsbuildinfo"
      ]
    },
    "test": {
      "command": "node --enable-source-maps --test \"./target/**/*.test.js\"",
      "dependencies": [
        "build"
      ]
    },
    "test:coverage": {
      "command": "node --enable-source-maps --experimental-test-coverage --test \"./target/**/*.test.js\"",
      "dependencies": [
        "build"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.0",
    "wireit": "^0.14.12"
  }
}
